# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.

PORT=5000

DB_USER=your_oracle_username
DB_PASSWORD=your_oracle_password
DB_CONNECT_STRING=host:port/service_name

GROQ_API_KEY=your_groq_api_key

# Generate your own with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# Optional -- both default to secure values (20 / 300 per 15 min) if unset.
# Only raise these on a machine doing active manual testing (many logins
# across a handful of shared test accounts trips the login limit
# legitimately); leave unset for anything closer to real go-live.
# AUTH_RATE_LIMIT_MAX=500
# API_RATE_LIMIT_MAX=2000

# Optional -- pino log level. Defaults to 'info' (or 'silent' under Jest).
# LOG_LEVEL=debug
